DOMAINS = config["interpro"]["target_interpro_ids"]

def get_accessions(wildcards):
    from json import load
    # Pass the target_domain wildcard to the checkpoint
    checkpoint_output = checkpoints.download_genomes.get(target_domain=wildcards.target_domain)
    with open(checkpoint_output.output.metadata) as f:
        metadata = load(f)
    return metadata["accessions"]


rule all:
    input:
        # update to where we're currently up to
        expand("results/03_motif_discovery/{target_domain}_domain_flanking_upstream/06_reports/analysis_summary.txt",
               target_domain=config["interpro"]["target_interpro_ids"]),
        expand("results/03_motif_discovery/{target_domain}_domain_flanking_upstream/06_reports/report.html",
               target_domain=config["interpro"]["target_interpro_ids"])

rule download_interpro_taxonomy:
    output:
        taxonomy = "resources/interpro/{target_domain}_taxonomy.json"
    params:
        interpro_id = "{target_domain}",
        interpro_base_url = lambda wildcards: config["databases"]["interpro"]["tax_base_url"],
        script = "workflow/src/download_interpro_taxonomy.py"
    log:
        "logs/{target_domain}_taxonomy/download_interpro_taxonomy_{target_domain}.log"
    conda:
        "envs/domain_taxonomy_env.yaml"
    shell:
        """
        python {params.script} \
            --interpro-id {params.interpro_id} \
            --interpro-tax-base-url {params.interpro_base_url} \
            --output {output.taxonomy} \
            2>&1 | tee {log}
        """

rule download_gtdb_data:
    output:
        tree = "resources/gtdb/bac120.tree",
        metadata = "resources/gtdb/bac120_metadata.tsv.gz"
    params:
        tree_url = config["databases"]["gtdb"]["gtdb_bacteria_tree_url"],
        metadata_url = config["databases"]["gtdb"]["gtdb_bacteria_metadata_url"],
        script = "workflow/src/download_gtdb.py"
    log:
        "logs/gtdb/download_gtdb_data.log"
    resources:
        mem_mb=8000,
        disk_mb=50000
    conda:
        "envs/domain_taxonomy_env.yaml"
    shell:
        """
        python {params.script} \
            --tree-url {params.tree_url} \
            --metadata-url {params.metadata_url} \
            --tree-output {output.tree} \
            --metadata-output {output.metadata} \
            2>&1 | tee {log}
        """

